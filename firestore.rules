rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Does the record belong to the authenticated user?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Bookings rules
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Saved Trips rules
    match /savedTrips/{tripId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Favorites rules
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Reviews rules (read is public, write is user-owned)
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
  }
}
